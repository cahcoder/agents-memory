#!/bin/bash
# Universal semantic memory wrapper - auto-detects AI tool

set -e

# === AUTO-DETECT AI TOOL ===
detect_tool() {
    if [[ "$CLAUDE_CODE" == "1" ]] || [[ -n "$CLAUDE_API_CONFIG" ]]; then
        echo "claude-code"
    elif [[ "$GEMINI_CLI" == "1" ]] || command -v gemini &>/dev/null; then
        echo "gemini-cli"
    elif [[ "$OPENCODE_DIR" != "" ]]; then
        echo "opencode"
    elif [[ "$CURSOR_DIR" != "" ]]; then
        echo "cursor"
    elif [[ -n "$CODECX_SESSION" ]]; then
        echo "codex"
    else
        # Check parent process
        local parent=$(ps -p $$ -o ppid= | xargs ps -o comm= 2>/dev/null | head -1)
        case "$parent" in
            *claude*) echo "claude-code" ;;
            *gemini*) echo "gemini-cli" ;;
            *opencode*) echo "opencode" ;;
            *) echo "unknown" ;;
        esac
    fi
}

# === PATHS ===
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="${SKILL_DIR:-$SCRIPT_DIR/../skill}"
MEMORY_DIR="${MEMORY_DIR:-$HOME/.memory/chroma}"

export SKILL_DIR
export MEMORY_DIR

# === COLORS ===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# === COMMANDS ===
cmd_search() {
    local query="$1"
    local project="${2:-default}"
    local limit="${3:-5}"
    
    echo -e "${YELLOW}🔍 Searching memory...${NC}"
    python3 "$SKILL_DIR/memory_search.py" "$query" --project "$project" --limit "$limit"
}

cmd_write() {
    local problem="$1"
    local solution="${2:-}"
    local project="${3:-default}"
    local type="${4:-solution}"
    
    echo -e "${YELLOW}💾 Storing to memory...${NC}"
    if [[ -n "$solution" ]]; then
        python3 "$SKILL_DIR/memory_write.py" "$problem" --solution "$solution" --type "$type" --project "$project"
    else
        # Read from stdin if no solution arg
        solution=$(cat)
        echo "$solution" | python3 "$SKILL_DIR/memory_write.py" "$problem" --solution - --type "$type" --project "$project"
    fi
}

cmd_bootstrap() {
    local project="$1"
    local architecture="${2:-}"
    
    echo -e "${YELLOW}🚀 Bootstrapping memory for: $project${NC}"
    if [[ -n "$architecture" ]]; then
        python3 "$SKILL_DIR/memory_bootstrap.py" "$project" --architecture "$architecture"
    else
        python3 "$SKILL_DIR/memory_bootstrap.py" "$project"
    fi
}

cmd_init() {
    local project="$1"
    
    echo -e "${YELLOW}🚀 Initializing memory...${NC}"
    python3 "$SKILL_DIR/memory_init.py" "$project"
}

cmd_init_project() {
    local project="$1"
    local folder="${2:-}"
    
    echo -e "${YELLOW}🚀 Initializing project folder: $folder${NC}"
    
    # Detect AI CLI tool to set project folder
    local project_dir=""
    case "$folder" in
        claude*) project_dir="~/claude-projects" ;;
        opencode*) project_dir="~/opencode/projects" ;;
        codex*|cursor*) project_dir="~/.cursor/projects" ;;
        *) project_dir="~/projects" ;;
    esac
    
    # Create project folder if not exists
    if [[ -n "$project_dir" ]]; then
        mkdir -p "$project_dir/$project" 2>/dev/null
    fi
    
    # Initialize project context via AGENTS.md
    AGENTS_MD="$HOME/.openclaw/workspace/AGENTS.md"
    
    # Create/append AGENTS.md project section
    echo "" >> "$AGENTS_MD"
    echo "## $project" >> "$AGENTS_MD"
    echo "" >> "$AGENTS_MD"
    echo "Date: $(date '+%Y-%m-%d')" >> "$AGENTS_MD"
    echo "" >> "$AGENTS_MD"
    
    # Add placeholder structure
    echo "### Tech Stack" >> "$AGENTS_MD"
    echo "- Framework:" >> "$AGENTS_MD"
    echo "- Database:" >> "$AGENTS_MD"
    echo "- Frontend:" >> "$AGENTS_MD"
    echo "- Other:" >> "$AGENTS_MD"
    echo "" >> "$AGENTS_MD"
    echo "### Workflow" >> "$AGENTS_MD"
    echo "- Build:" >> "$AGENTS_MD"
    echo "- Test:" >> "$AGENTS_MD"
    echo "- Deploy:" >> "$AGENTS_MD"
    echo "" >> "$AGENTS_MD"
    echo "### Important Notes" >> "$AGENTS_MD"
    echo "Any critical decisions, constraints, or rules for this project." >> "$AGENTS_MD"
    
    echo "Project initialized at $project_dir/$project" >> "$AGENTS_MD"
}

cmd_gc() {
    echo -e "${YELLOW}🧹 Garbage collection...${NC}"
    python3 "$SKILL_DIR/memory_gc.py" "$@"
}

cmd_stats() {
    python3 "$SKILL_DIR/memory_gc.py" --stats
}

cmd_intelligence() {
    local subcmd="${1:-patterns}"
    python3 "$SCRIPT_DIR/intelligence.py" "$subcmd"
}

cmd_pre() {
    # For pre-LLM hook: output context only, no extra text
    local input="$1"
    local project="${2:-default}"
    
    # Query for context (uses LAWS_LIMIT env var for laws collection)
    local limit="${LAWS_LIMIT:-}"
    python3 "$SKILL_DIR/memory_search.py" "$input" --project "$project" --limit "$limit" 2>/dev/null
}

cmd_post() {
    # For post-LLM hook: store without verbose output
    local problem="$1"
    local solution="${2}"
    local project="${3:-default}"
    
    python3 "$SKILL_DIR/memory_write.py" "$problem" --solution "$solution" --type solution --project "$project" 2>/dev/null
}

# === HELP ===
show_help() {
    cat << EOF
${GREEN}🧠 Semantic Memory Wrapper${NC}

Usage: memory <command> [args]

Commands:
  init                      Initialize project context (reads AGENTS.md)
  init-project <name> [folder]  Initialize project folder and AGENTS.md entry
  search <query> [project] [limit]    Search memory (supports LAWS_LIMIT env for laws)
  write <problem> [solution] [project] Store learning
  bootstrap <project> [arch]          Init project memory
  gc [options]                        Garbage collection
  stats                               Show memory stats
  pre <input> [project]               PRE-LLM hook (uses LAWS_LIMIT for laws)
  post <problem> <solution> [proj]    POST-LLM hook

Environment Variables:
  SKILL_DIR    Path to skill scripts (default: ~/semantic-clawmemory/skill)
  MEMORY_DIR   Path to Chroma DB (default: ~/.memory/chroma)
  LAWS_LIMIT  Limit for laws collection queries (default: 5, set to 0 for unlimited)

Examples:
  # Initialize project (reads AGENTS.md)
  memory init
  
  # Initialize project folder + AGENTS.md
  memory init-project myproject --folder ~/claude-projects
  
  # Search (uses LAWS_LIMIT for laws)
  memory search "postgres restart"
  LAWS_LIMIT=0 memory search laws  # Get all laws
  
  # Store learning
  memory write "container crash" "docker restart"

EOF
}

# === MAIN ===
CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
    init)              cmd_init "$@" ;;
    init-project)       cmd_init_project "$@" ;;
    search)            cmd_search "$@" ;;
    write)             cmd_write "$@" ;;
    bootstrap)          cmd_bootstrap "$@" ;;
    gc)                 cmd_gc "$@" ;;
    stats)              cmd_stats ;;
    pre)                cmd_pre "$@" ;;
    post)               cmd_post "$@" ;;
    -h|--help|help)   show_help ;;
    *)         
        if [[ -z "$CMD" ]]; then
            show_help
        else
            echo -e "${RED}Unknown command: $CMD${NC}"
            show_help
            exit 1
        fi
        ;;
esac
