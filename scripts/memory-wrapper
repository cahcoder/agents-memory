#!/bin/bash
# memory-wrapper - Universal memory wrapper for AI CLI tools
# Wraps any AI CLI tool and injects memory context automatically

set -e

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(dirname "$SCRIPT_DIR")/skill"
MEMORY_DIR="${MEMORY_DIR:-$HOME/.memory/chroma}"
PYTHON_BIN="${PYTHON_BIN:-python3}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging
log() {
    echo -e "${BLUE}[memory]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[memory]${NC} $1"
}

error() {
    echo -e "${RED}[memory]${NC} $1" >&2
}

# Check dependencies
check_deps() {
    if ! command -v "$PYTHON_BIN" &> /dev/null; then
        error "Python 3 not found. Please install Python 3.8+"
        exit 1
    fi
    
    # Check Python packages
    if ! "$PYTHON_BIN" -c "import chromadb" 2>/dev/null; then
        warn "ChromaDB not installed. Installing..."
        "$PYTHON_BIN" -m pip install chromadb sentence-transformers --quiet
    fi
}

# Initialize memory if empty
init_memory() {
    if [ ! -d "$MEMORY_DIR" ]; then
        log "Initializing memory directory..."
        mkdir -p "$MEMORY_DIR"
    fi
}

# Search memory
search_memory() {
    local query="$1"
    local project="${2:-}"
    local limit="${3:-5}"
    
    check_deps
    init_memory
    
    local args=("$SKILL_DIR/memory_search.py" "$query" "--limit" "$limit")
    
    if [ -n "$project" ]; then
        args+=("--project" "$project")
    fi
    
    "$PYTHON_BIN" "${args[@]}"
}

# Write to memory
write_memory() {
    local problem="$1"
    local solution="${2:-}"
    local project="${3:-}"
    local type="${4:-solution}"
    
    check_deps
    init_memory
    
    local args=("$SKILL_DIR/memory_write.py" "$problem")
    
    if [ -n "$solution" ]; then
        args+=("--solution" "$solution")
    fi
    
    if [ -n "$project" ]; then
        args+=("--project" "$project")
    fi
    
    if [ -n "$type" ]; then
        args+=("--type" "$type")
    fi
    
    "$PYTHON_BIN" "${args[@]}"
}

# PRE-LLM hook
pre_llm() {
    local input="$1"
    local project="${2:-}"
    
    check_deps
    init_memory
    
    local args=("$SKILL_DIR/memory_pre_llm.py" "$input")
    
    if [ -n "$project" ]; then
        args+=("--project" "$project")
    fi
    
    "$PYTHON_BIN" "${args[@]}"
}

# POST-LLM hook
post_llm() {
    local input="$1"
    local response="$2"
    local project="${3:-}"
    
    check_deps
    init_memory
    
    local args=("$SKILL_DIR/memory_post_llm.py" "$input" "$response")
    
    if [ -n "$project" ]; then
        args+=("--project" "$project")
    fi
    
    "$PYTHON_BIN" "${args[@]}"
}

# Bootstrap new project
bootstrap_project() {
    local project="$1"
    local architecture="${2:-}"
    local tech_stack="${3:-}"
    
    check_deps
    init_memory
    
    local args=("$SKILL_DIR/memory_bootstrap.py" "$project")
    
    if [ -n "$architecture" ]; then
        args+=("--architecture" "$architecture")
    fi
    
    if [ -n "$tech_stack" ]; then
        args+=("--tech-stack" "$tech_stack")
    fi
    
    "$PYTHON_BIN" "${args[@]}"
}

# Garbage collection
gc() {
    check_deps
    
    "$PYTHON_BIN" "$SKILL_DIR/memory_gc.py" "$@"
}

# Intelligence
intelligence() {
    check_deps
    
    "$PYTHON_BIN" "$SCRIPT_DIR/intelligence.py" "$@"
}

# Wrap a command with memory
wrap_command() {
    local cmd="$@"
    local project="${PROJECT:-default}"
    
    log "Memory-enhanced execution"
    log "Project: $project"
    
    # Execute the command (actual wrapping depends on the tool)
    eval "$cmd"
}

# Show help
show_help() {
    cat << EOF
${GREEN}semantic-clawmemory${NC} - Universal semantic memory for AI CLI tools

${YELLOW}Usage:${NC}
    memory-wrapper [command] [options]

${YELLOW}Commands:${NC}
    search <query> [project] [limit]    Search memory
    write <problem> [solution] [project] [type]  Write to memory
    pre <input> [project]               PRE-LLM hook
    post <input> <response> [project]    POST-LLM hook
    bootstrap <project> [arch] [stack]   Bootstrap new project
    gc [options]                        Garbage collection
    intelligence [command]               Intelligence module
    wrap <command>                      Wrap any AI CLI command

${YELLOW}Environment Variables:${NC}
    MEMORY_DIR    Memory database directory (default: ~/.memory/chroma)
    PROJECT       Current project name
    PYTHON_BIN    Python binary path (default: python3)

${YELLOW}Examples:${NC}
    memory-wrapper search "postgres restart"
    memory-wrapper write "container crash" "docker restart" "myproject"
    memory-wrapper pre "how to setup postgres"
    PROJECT=myproject memory-wrapper wrap "claude-code"

EOF
}

# Main
case "${1:-}" in
    search)
        search_memory "${2:-}" "${3:-}" "${4:-5}"
        ;;
    write)
        write_memory "${2:-}" "${3:-}" "${4:-}" "${5:-solution}"
        ;;
    pre)
        pre_llm "${2:-}" "${3:-}"
        ;;
    post)
        post_llm "${2:-}" "${3:-}" "${4:-}"
        ;;
    bootstrap)
        bootstrap_project "${2:-}" "${3:-}" "${4:-}"
        ;;
    gc)
        shift
        gc "$@"
        ;;
    intelligence|intel)
        shift
        intelligence "$@"
        ;;
    wrap)
        shift
        wrap_command "$@"
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
